rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return request.auth != null && currentUser().role == 'admin';
    }

    function isActiveRole(role) {
      return request.auth != null && currentUser().role == role && currentUser().status == 'active';
    }

    // --- Public content (homepage / static pages) ---
    // Read: anyone. Write: admin only — regular mentor/teacher accounts also
    // authenticate now, so "signed in" alone is no longer enough to write.
    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /courses/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /schools/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /assistants/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /org/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /carouselSlides/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- School options (dropdown shown during teacher onboarding) ---
    match /schoolOptions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Name rosters used to auto-approve onboarding ---
    // Only a targeted get-by-id is allowed (never list), so the client can
    // check "does my exact name exist?" without being able to dump the whole
    // roster. Admin manages the contents out-of-band (seed script/console).
    match /roster_mentor/{name} {
      allow get: if request.auth != null;
      allow list: if false;
      allow write: if isAdmin();
    }

    match /roster_teacher/{name} {
      allow get: if request.auth != null;
      allow list: if false;
      allow write: if isAdmin();
    }

    // --- Accounts ---
    // Self-registration creates a mentor/teacher profile that can't grant
    // itself admin. Its status is only allowed to be 'active' when it truly
    // matches the corresponding name roster — the exists() check re-verifies
    // this server-side, so the client can't just lie and claim 'active'.
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.email == request.auth.token.email
        && (
          (request.resource.data.role == 'mentor'
            && request.resource.data.status == (
              exists(/databases/$(database)/documents/roster_mentor/$(request.resource.data.name))
                ? 'active' : 'pending'
            ))
          || (request.resource.data.role == 'teacher'
            && request.resource.data.status == (
              exists(/databases/$(database)/documents/roster_teacher/$(request.resource.data.name))
                ? 'active' : 'pending'
            ))
        );
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && request.resource.data.status == resource.data.status);
      allow delete: if isAdmin();
    }

    // --- Course schedule master file (admin uploads, everyone logged in reads) ---
    match /courseSchedule/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // --- Mentor lesson plan uploads ---
    match /lessonPlans/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.mentorUid == request.auth.uid);
      allow create: if isActiveRole('mentor') && request.resource.data.mentorUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Teacher survey uploads ---
    match /surveyUploads/{docId} {
      allow read: if request.auth != null && (isAdmin() || resource.data.teacherUid == request.auth.uid);
      allow create: if isActiveRole('teacher') && request.resource.data.teacherUid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
