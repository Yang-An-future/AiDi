rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Public content collections: anyone can read, only signed-in admins can write.
    // "Signed-in" == exists as a Firebase Auth user; there's currently a single
    // admin role, so authentication alone is treated as authorization.
    match /announcements/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /courses/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /reviews/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /schools/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /assistants/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /org/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
