# --- Firebase (client SDK) ---
# From Firebase Console > Project settings > General > Your apps > Web app.
# These are bundled into the frontend build (not secret) — VITE_ prefix is
# required for Vite to expose them to browser code via import.meta.env.
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="my-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="my-project"
VITE_FIREBASE_STORAGE_BUCKET="my-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="1234567890"
VITE_FIREBASE_APP_ID="1:1234567890:web:abc123"

# --- Firebase (Admin SDK, server-only) ---
# From Firebase Console > Project settings > Service accounts > Generate new
# private key. Paste the ENTIRE downloaded JSON file as a single-line string
# (or base64-encode it) into this variable. NEVER commit the real value or the
# downloaded JSON file — keep this only in .env.local / Render's env settings.
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
